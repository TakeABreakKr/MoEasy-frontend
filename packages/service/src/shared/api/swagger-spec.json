{
  "openapi": "3.0.0",
  "paths": {
    "/meeting/create": {
      "post": {
        "operationId": "MeetingController_createMeeting",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": { "multipart/form-data": { "schema": { "$ref": "#/components/schemas/CreateMeetingRequest" } } }
        },
        "responses": { "200": { "description": "Meeting Entity has been successfully created." } },
        "tags": ["meeting"],
        "security": [{ "bearer": [] }]
      }
    },
    "/meeting/update": {
      "post": {
        "operationId": "MeetingController_updateMeeting",
        "parameters": [],
        "requestBody": {
          "required": true,
          "description": "Basic values to modify meetings",
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateMeetingRequest" } } }
        },
        "responses": { "200": { "description": "Meeting Entity has been successfully modified." } },
        "tags": ["meeting"],
        "security": [{ "bearer": [] }]
      }
    },
    "/meeting/get": {
      "get": {
        "operationId": "MeetingController_getMeeting",
        "parameters": [{ "name": "meetingId", "required": true, "in": "query", "schema": { "type": "number" } }],
        "responses": { "200": { "description": "Meeting retrieved successfully" } },
        "tags": ["meeting"]
      }
    }
  },
  "info": { "title": "MoEasy Backend", "description": "MoEasy Backend API", "version": "0.0.1", "contact": {} },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "CreateMeetingRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "explanation": { "type": "string" },
          "limit": { "type": "number" },
          "members": { "type": "array", "items": { "type": "string" } },
          "thumbnail": { "type": "string", "format": "binary" }
        },
        "required": ["name", "explanation", "limit", "members", "thumbnail"]
      },
      "UpdateMeetingRequest": {
        "type": "object",
        "properties": {
          "meeting_id": { "type": "number" },
          "name": { "type": "string" },
          "explanation": { "type": "string" },
          "limit": { "type": "number" }
        },
        "required": ["meeting_id", "name", "explanation", "limit"]
      }
    }
  }
}
